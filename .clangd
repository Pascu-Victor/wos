Diagnostics:
    ClangTidy:
        Add:
            - "bugprone-*"
            - "clang-analyzer-*"
            - "readability-*"
            - "performance-*"
            - "misc-*"
            - "modernize-*"
            - "cppcoreguidelines-*"
        Remove:
            - readability-identifier-length
            - cppcoreguidelines-pro-type-reinterpret-cast
            - cppcoreguidelines-owning-memory
            - cppcoreguidelines-pro-bounds-pointer-arithmetic
            - cppcoreguidelines-avoid-non-const-global-variables
            - cppcoreguidelines-pro-type-cstyle-cast
            - cppcoreguidelines-pro-type-union-access
            - bugprone-easily-swappable-parameters
            - bugprone-reserved-identifier
            - misc-non-private-member-variables-in-classes

    Includes:
        IgnoreHeader: ".*toolchain/target1/.*"
    UnusedIncludes: Strict
    MissingIncludes: Strict

CompileFlags:
    Remove:
        - -w-reloc-rel-dword
        - -w-reloc-abs-qword
        - -f
        - -fsanitize=safe-stack
        - -felf64
        - -fPIE
        - -pie
        - -resource-dir=/usr/lib/clang/20
        - -std=c++*
        - -std=c1*
        - -std=c2*

Index:
    Background: Build

InlayHints:
    Enabled: true
    ParameterNames: true
    DeducedTypes: true

Hover:
    ShowAKA: true

---

# C-only third-party trees: no compile_commands.json so clangd defaults to
# clang++, which rejects -std=c11. Force the C driver explicitly.
If:
    PathMatch: ".*/(busybox|dropbear)/.*\\.c$"
CompileFlags:
    Compiler: clang
    Add:
        - -std=c11
    Remove:
        - -std=c++*

---

If:
    PathMatch: ".*\\.(cpp|cxx|cc|hpp|hxx|hh)$"
CompileFlags:
    Add:
        - -std=c++23

---

If:
    PathMatch: ".*\\.c$"
    PathExclude: ".*/(busybox|dropbear)/.*"
CompileFlags:
    Add:
        - -std=c11
