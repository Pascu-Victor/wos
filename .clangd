If:
    PathExclude: "toolchain/src/llvm-project/.*"
Diagnostics:
    Includes:
        IgnoreHeader: ".*toolchain/sysroot/.*"
    UnusedIncludes: Strict
    MissingIncludes: Strict

CompileFlags:
    Add:
        - -D_GLIBCXX_HOSTED
    Remove:
        - -w-reloc-rel-dword
        - -w-reloc-abs-qword
        - -f
        - -fsanitize=safe-stack
        - -felf64
        - -fPIE
        - -pie
        - -resource-dir=/usr/lib/clang/20
        - -std=c++*
        - -std=c1*
        - -std=c2*
        - -fsanitize=kernel-address

Index:
    Background: Build

InlayHints:
    Enabled: true
    ParameterNames: true
    DeducedTypes: true

Hover:
    ShowAKA: true

---
# C-only third-party trees: no compile_commands.json so clangd defaults to
# clang++, which rejects -std=c11. Force the C driver explicitly.
If:
    PathMatch: ".*/busybox/.*\\.c$"
CompileFlags:
    Compiler: clang
    Add:
        - -std=c11
        - -Itoolchain/src/busybox/include
        - -Itoolchain/src/busybox/libbb
    Remove:
        - -std=c++*

---
If:
    PathMatch: ".*/dropbear/.*\\.c$"
CompileFlags:
    Compiler: clang
    Add:
        - -std=c11
    Remove:
        - -std=c++*

---
If:
    PathMatch: ".*\\.(cpp|cxx|cc|hpp|hxx|hh)$"
    PathExclude:
        - "toolchain/src/llvm-project/.*"
        - "tools/.*"
CompileFlags:
    Add:
        - -std=c++23
        - -D_DEFAULT_SOURCE
        - -D__WOS__=1
        - -D_GNU_SOURCE=1

---
If:
    PathMatch: ".*\\.c$"
    PathExclude:
        - ".*/(busybox|dropbear)/.*"
        - "toolchain/src/llvm-project/.*"
CompileFlags:
    Add:
        - -std=c11
