    "version": "0.2.0",
    "configurations": [
        {
            "type": "lldb-dap",
            "request": "attach",
            "name": "Attach httpd",
            "preRunCommands": [
                "target create ${workspaceFolder}/build/modules/httpd/httpd"
            ],
            "initCommands": [
                "settings set target.x86-disassembly-flavor intel",
                "settings set target.load-script-from-symbol-file false",
                "settings set target.process.thread.step-in-avoid-nodebug false",
                "settings set target.require-hardware-breakpoint true",
                "command alias b breakpoint set --hardware",
                "command alias hbreak breakpoint set --hardware",
            ],
            "attachCommands": [
                "gdb-remote 10.10.0.235:4321"
            ],
        },
        {
            "name": "Debug WOS Kernel",
