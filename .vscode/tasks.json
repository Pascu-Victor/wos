{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build WOS",
            "command": "${workspaceFolder}/scripts/dev/build_wos.sh",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "bash",
                    "args": [
                        "-c"
                    ]
                },
                "env": {
                    "WOS_ENV_LOADED": "1",
                    "WOS_WORKSPACE_ROOT": "${workspaceFolder}",
                    "WOS_TOOLCHAIN_ROOT": "${workspaceFolder}/toolchain",
                    "WOS_TARGET_ARCH": "x86_64-pc-wos",
                    "WOS_SYSROOT": "${workspaceFolder}/toolchain/sysroot",
                    "WOS_CLANG_VERSION": "22",
                    "CC": "${workspaceFolder}/toolchain/host/bin/clang",
                    "CXX": "${workspaceFolder}/toolchain/host/bin/clang++",
                    "LD": "${workspaceFolder}/toolchain/host/bin/ld.lld",
                    "CFLAGS": "--sysroot=${workspaceFolder}/toolchain/sysroot -std=c23",
                    "CXXFLAGS": "--sysroot=${workspaceFolder}/toolchain/sysroot -std=c++23",
                    "LDFLAGS": "--sysroot=${workspaceFolder}/toolchain/sysroot",
                    "NINJA_STATUS": "[%f/%t %e] ",
                    "PATH": "${workspaceFolder}/bin:${workspaceFolder}/toolchain/host/bin:${workspaceFolder}/tools/build/bin:${env:PATH}",
                    "LD_LIBRARY_PATH": "${workspaceFolder}/toolchain/host/lib"
                }
            },
            "isBackground": false,
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always"
            }
        },
        {
            "label": "Start WOS Cluster",
            "command": "${workspaceFolder}/bin/wos-cluster --launch",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "bash",
                    "args": [
                        "-c"
                    ]
                },
                "env": {
                    "WOS_ENV_LOADED": "1",
                    "WOS_WORKSPACE_ROOT": "${workspaceFolder}",
                    "WOS_TOOLCHAIN_ROOT": "${workspaceFolder}/toolchain",
                    "WOS_TARGET_ARCH": "x86_64-pc-wos",
                    "WOS_SYSROOT": "${workspaceFolder}/toolchain/sysroot",
                    "WOS_CLANG_VERSION": "22",
                    "CC": "${workspaceFolder}/toolchain/host/bin/clang",
                    "CXX": "${workspaceFolder}/toolchain/host/bin/clang++",
                    "LD": "${workspaceFolder}/toolchain/host/bin/ld.lld",
                    "CFLAGS": "--sysroot=${workspaceFolder}/toolchain/sysroot -std=c23",
                    "CXXFLAGS": "--sysroot=${workspaceFolder}/toolchain/sysroot -std=c++23",
                    "LDFLAGS": "--sysroot=${workspaceFolder}/toolchain/sysroot",
                    "NINJA_STATUS": "[%f/%t %e] ",
                    "PATH": "${workspaceFolder}/bin:${workspaceFolder}/toolchain/host/bin:${workspaceFolder}/tools/build/bin:${env:PATH}",
                    "LD_LIBRARY_PATH": "${workspaceFolder}/toolchain/host/lib"
                }
            },
            "isBackground": true,
            "problemMatcher": [
                {
                    "pattern": [
                        {
                            "regexp": "^([^\\s].*):(\\d+): (.*)$",
                            "file": 1,
                            "line": 2,
                            "message": 3
                        }
                    ],
                    "background": {
                        "activeOnStart": true,
                        "beginsPattern": "=== Launching VMs ===",
                        "endsPattern": "Press Ctrl\\+C to stop all VMs"
                    }
                }
            ],
            "presentation": {
                "reveal": "always"
            },
            "group": "build"
        },
        {
            "label": "Start WOS Cluster Debug",
            "command": "${workspaceFolder}/bin/wos-cluster --launch --debug-node 0",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "bash",
                    "args": [
                        "-c"
                    ]
                },
                "env": {
                    "WOS_ENV_LOADED": "1",
                    "WOS_WORKSPACE_ROOT": "${workspaceFolder}",
                    "WOS_TOOLCHAIN_ROOT": "${workspaceFolder}/toolchain",
                    "WOS_TARGET_ARCH": "x86_64-pc-wos",
                    "WOS_SYSROOT": "${workspaceFolder}/toolchain/sysroot",
                    "WOS_CLANG_VERSION": "22",
                    "CC": "${workspaceFolder}/toolchain/host/bin/clang",
                    "CXX": "${workspaceFolder}/toolchain/host/bin/clang++",
                    "LD": "${workspaceFolder}/toolchain/host/bin/ld.lld",
                    "CFLAGS": "--sysroot=${workspaceFolder}/toolchain/sysroot -std=c23",
                    "CXXFLAGS": "--sysroot=${workspaceFolder}/toolchain/sysroot -std=c++23",
                    "LDFLAGS": "--sysroot=${workspaceFolder}/toolchain/sysroot",
                    "NINJA_STATUS": "[%f/%t %e] ",
                    "PATH": "${workspaceFolder}/bin:${workspaceFolder}/toolchain/host/bin:${workspaceFolder}/tools/build/bin:${env:PATH}",
                    "LD_LIBRARY_PATH": "${workspaceFolder}/toolchain/host/lib"
                }
            },
            "isBackground": true,
            "problemMatcher": [
                {
                    "pattern": [
                        {
                            "regexp": "^([^\\s].*):(\\d+): (.*)$",
                            "file": 1,
                            "line": 2,
                            "message": 3
                        }
                    ],
                    "background": {
                        "activeOnStart": true,
                        "beginsPattern": "=== Launching VMs ===",
                        "endsPattern": "Press Ctrl\\+C to stop all VMs"
                    }
                }
            ],
            "presentation": {
                "reveal": "always"
            },
            "group": "build"
        },
        {
            "label": "Build and Start Cluster Debug",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Build WOS",
                "Start WOS Cluster Debug"
            ],
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "Build wosdbg",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build/tools",
                "--target",
                "wosdbg"
            ],
            "isBackground": false,
            "group": "build"
        }
    ]
}
