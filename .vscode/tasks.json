{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build WOS",
            "command": "cmake -B build -GNinja . && cmake --build build --target wos_full",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "bash",
                    "args": [
                        "-c"
                    ]
                },
                "env": {
                    "WOS_ENV_LOADED": "1",
                    "WOS_WORKSPACE_ROOT": "${workspaceFolder}",
                    "WOS_TOOLCHAIN_ROOT": "${workspaceFolder}/toolchain",
                    "WOS_TARGET_ARCH": "x86_64-pc-wos",
                    "WOS_SYSROOT": "${workspaceFolder}/toolchain/sysroot",
                    "WOS_CLANG_VERSION": "22",
                    "CC": "${workspaceFolder}/toolchain/host/bin/clang",
                    "CXX": "${workspaceFolder}/toolchain/host/bin/clang++",
                    "LD": "${workspaceFolder}/toolchain/host/bin/ld.lld",
                    "CFLAGS": "--sysroot=${workspaceFolder}/toolchain/sysroot -std=c23",
                    "CXXFLAGS": "--sysroot=${workspaceFolder}/toolchain/sysroot -std=c++23",
                    "LDFLAGS": "--sysroot=${workspaceFolder}/toolchain/sysroot",
                    "NINJA_STATUS": "[%f/%t %e] ",
                    "PATH": "${workspaceFolder}/toolchain/host/bin:${workspaceFolder}/tools/build/bin:${env:PATH}",
                    "LD_LIBRARY_PATH": "${workspaceFolder}/toolchain/host/lib"
                }
            },
            "isBackground": false,
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always"
            }
        },
        {
            "label": "runWosKern",
            "command": "${workspaceFolder}/scripts/run_kern.sh",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "bash",
                    "args": [
                        "--init-file",
                        "${workspaceFolder}/.vscode/wos-env.sh"
                    ]
                }
            },
            "args": [],
            "isBackground": true,
            "problemMatcher": [
                "$tsc",
                {
                    "pattern": [
                        {
                            "regexp": ".",
                            "file": 1,
                            "location": 2,
                            "message": 3
                        }
                    ],
                    "background": {
                        "activeOnStart": true,
                        "beginsPattern": ".",
                        "endsPattern": "."
                    }
                }
            ],
            "presentation": {
                "reveal": "always"
            },
            "group": "build"
        },
        {
            "label": "Build and Start QEMU",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Build WOS",
                "Start QEMU Debug"
            ],
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "Start QEMU Debug",
            "command": "${workspaceFolder}/scripts/run_kern.sh --debug",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "bash",
                    "args": [
                        "-c"
                    ]
                },
                "env": {
                    "WOS_ENV_LOADED": "1",
                    "WOS_WORKSPACE_ROOT": "${workspaceFolder}",
                    "WOS_TOOLCHAIN_ROOT": "${workspaceFolder}/toolchain",
                    "WOS_TARGET_ARCH": "x86_64-pc-wos",
                    "WOS_SYSROOT": "${workspaceFolder}/toolchain/sysroot",
                    "WOS_CLANG_VERSION": "22",
                    "CC": "${workspaceFolder}/toolchain/host/bin/clang",
                    "CXX": "${workspaceFolder}/toolchain/host/bin/clang++",
                    "LD": "${workspaceFolder}/toolchain/host/bin/ld.lld",
                    "CFLAGS": "--sysroot=${workspaceFolder}/toolchain/sysroot -std=c23",
                    "CXXFLAGS": "--sysroot=${workspaceFolder}/toolchain/sysroot -std=c++23",
                    "LDFLAGS": "--sysroot=${workspaceFolder}/toolchain/sysroot",
                    "NINJA_STATUS": "[%f/%t %e] ",
                    "PATH": "${workspaceFolder}/toolchain/host/bin:${workspaceFolder}/tools/build/bin:${env:PATH}",
                    "LD_LIBRARY_PATH": "${workspaceFolder}/toolchain/host/lib"
                }
            },
            "isBackground": true,
            "problemMatcher": [
                {
                    "pattern": [
                        {
                            "regexp": "^([^\\s].*):(\\d+): (.*)$",
                            "file": 1,
                            "line": 2,
                            "message": 3
                        }
                    ],
                    "background": {
                        "activeOnStart": true,
                        "beginsPattern": "STARTING BOOT:",
                        "endsPattern": "QEMU .* monitor - type 'help' for more information"
                    }
                }
            ],
            "presentation": {
                "reveal": "always"
            },
            "group": "build"
        },
        {
            "label": "Start Cluster Background",
            "command": "${workspaceFolder}/scripts/run_cluster.sh 3 --skip 1",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "bash",
                    "args": [
                        "-c"
                    ]
                },
                "env": {
                    "WOS_ENV_LOADED": "1",
                    "WOS_WORKSPACE_ROOT": "${workspaceFolder}",
                    "WOS_TOOLCHAIN_ROOT": "${workspaceFolder}/toolchain",
                    "WOS_TARGET_ARCH": "x86_64-pc-wos",
                    "WOS_SYSROOT": "${workspaceFolder}/toolchain/sysroot",
                    "WOS_CLANG_VERSION": "22",
                    "CC": "${workspaceFolder}/toolchain/host/bin/clang",
                    "CXX": "${workspaceFolder}/toolchain/host/bin/clang++",
                    "LD": "${workspaceFolder}/toolchain/host/bin/ld.lld",
                    "CFLAGS": "--sysroot=${workspaceFolder}/toolchain/sysroot -std=c23",
                    "CXXFLAGS": "--sysroot=${workspaceFolder}/toolchain/sysroot -std=c++23",
                    "LDFLAGS": "--sysroot=${workspaceFolder}/toolchain/sysroot",
                    "NINJA_STATUS": "[%f/%t %e] ",
                    "PATH": "${workspaceFolder}/toolchain/host/bin:${workspaceFolder}/tools/build/bin:${env:PATH}",
                    "LD_LIBRARY_PATH": "${workspaceFolder}/toolchain/host/lib"
                }
            },
            "isBackground": true,
            "problemMatcher": [
                {
                    "pattern": [
                        {
                            "regexp": "^([^\\s].*):(\\d+): (.*)$",
                            "file": 1,
                            "line": 2,
                            "message": 3
                        }
                    ],
                    "background": {
                        "activeOnStart": true,
                        "beginsPattern": "=== WKI Cluster:",
                        "endsPattern": "Press Ctrl\\+C to stop all VMs"
                    }
                }
            ],
            "presentation": {
                "reveal": "always"
            },
            "group": "build"
        },
        {
            "label": "Start Cluster and Debug VM",
            "dependsOrder": "parallel",
            "dependsOn": [
                "Start Cluster Background",
                "Start QEMU Debug"
            ],
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "Build and Start Cluster Debug",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Build WOS",
                "Start Cluster and Debug VM"
            ],
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "Build wosdbg",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build/tools",
                "--target",
                "wosdbg"
            ],
            "isBackground": false,
            "group": "build"
        }
    ]
}